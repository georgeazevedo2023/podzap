# ============================================================================
# podZAP — PRODUCTION env template (Portainer)
# ============================================================================
# Template for Portainer environment variables — copy values into the Portainer
# stack's "Environment variables" tab, NOT into a .env file on the host.
#
# The stack file (docker-compose.stack.yml) references these via ${VAR_NAME}.
# NODE_ENV, NEXT_PUBLIC_APP_URL and APP_URL are HARDCODED in the stack file —
# they are listed here for completeness but Portainer will ignore them if you
# paste them in (the stack overrides).
# ============================================================================


# ----------------------------------------------------------------------------
# APP  (hardcoded in docker-compose.stack.yml — listed here for reference)
# ----------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://podzap.wsmart.com.br
APP_URL=https://podzap.wsmart.com.br


# ----------------------------------------------------------------------------
# SUPABASE  (prod project — NOT the dev/local one)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=


# ----------------------------------------------------------------------------
# UAZAPI  (same instance as dev is OK — just point the webhook at prod domain)
# ----------------------------------------------------------------------------
UAZAPI_BASE_URL=https://wsmart.uazapi.com
UAZAPI_ADMIN_TOKEN=
# openssl rand -hex 32  — must match webhook config pushed to UAZAPI
UAZAPI_WEBHOOK_SECRET=


# ----------------------------------------------------------------------------
# GROQ
# ----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3


# ----------------------------------------------------------------------------
# GEMINI
# ----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_LLM_MODEL=gemini-2.5-pro
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts


# ----------------------------------------------------------------------------
# OPENAI (optional fallback)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4.1-mini


# ----------------------------------------------------------------------------
# INNGEST  — Cloud only in prod.
# DO NOT set INNGEST_DEV here. The stack file intentionally omits it.
# Get keys from https://app.inngest.com → Environments → Production
# ----------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=


# ----------------------------------------------------------------------------
# SECURITY
# IMPORTANT: generate fresh values — do NOT reuse the dev keys.
# Rotating ENCRYPTION_KEY after go-live will invalidate every stored UAZAPI
# instance token (tenants will need to reconnect), so pick once and keep safe.
# ----------------------------------------------------------------------------
# openssl rand -base64 32
ENCRYPTION_KEY=
# openssl rand -hex 32
CRON_SECRET=
