# ============================================================================
# podZAP — template de variáveis de ambiente
# ============================================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local.
# ============================================================================


# ----------------------------------------------------------------------------
# APP
# ----------------------------------------------------------------------------
# URL pública do app (http://localhost:3000 em dev, domínio em prod)
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# "development" | "production"
NODE_ENV=development


# ----------------------------------------------------------------------------
# SUPABASE
# ----------------------------------------------------------------------------
# Crie um projeto em https://supabase.com/dashboard → New project
# Copie os valores em: Project Settings → API

# URL do projeto (algo como https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon key — pública, usada no client browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role key — SECRETA, só no servidor/workers, bypassa RLS
SUPABASE_SERVICE_ROLE_KEY=

# Connection string do Postgres (Project Settings → Database)
# usada para migrations e clients diretos
DATABASE_URL=


# ----------------------------------------------------------------------------
# UAZAPI — WhatsApp
# ----------------------------------------------------------------------------
# URL da instância UAZAPI (ex: https://free.uazapi.com ou self-hosted)
UAZAPI_BASE_URL=https://free.uazapi.com

# Token admin da sua conta UAZAPI (para criar instâncias)
# Encontre em: painel UAZAPI → admin
UAZAPI_ADMIN_TOKEN=

# Secret usado para validar webhooks vindos da UAZAPI
# Gere com: openssl rand -hex 32
UAZAPI_WEBHOOK_SECRET=


# ----------------------------------------------------------------------------
# GROQ — transcrição de áudio
# ----------------------------------------------------------------------------
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# Modelo de transcrição (Whisper Large v3 é o padrão recomendado)
GROQ_STT_MODEL=whisper-large-v3


# ----------------------------------------------------------------------------
# GEMINI — Vision + LLM + TTS
# ----------------------------------------------------------------------------
# Obtenha em: https://aistudio.google.com/apikey
# A mesma chave serve para Vision, LLM e Speech
GEMINI_API_KEY=

# Modelos (valores padrão recomendados)
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_LLM_MODEL=gemini-2.5-pro
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts


# ----------------------------------------------------------------------------
# OPENAI — fallback LLM (opcional)
# ----------------------------------------------------------------------------
# Só necessário se quiser fallback quando Gemini falhar
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4.1-mini


# ----------------------------------------------------------------------------
# INNGEST — workers/filas
# ----------------------------------------------------------------------------
# Em dev, deixe em branco e rode `npx inngest-cli dev`
# Em prod, obtenha em https://app.inngest.com/
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=


# ----------------------------------------------------------------------------
# SEGURANÇA
# ----------------------------------------------------------------------------
# Chave para encriptar tokens da UAZAPI no banco (AES-256)
# Gere com: openssl rand -base64 32
ENCRYPTION_KEY=

# Secret para jobs cron autenticados
# Gere com: openssl rand -hex 32
CRON_SECRET=
