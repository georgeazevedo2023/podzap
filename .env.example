# ============================================================================
# podZAP — template de variáveis de ambiente
# ============================================================================
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA commite o .env.local.
#
# Legenda:
#   [required] app/workers não sobem sem esta var (código faz throw / coerção
#              com `!` / `requireEnv`).
#   [optional] tem fallback em código (default model, URL, etc).
#   [script]   consumido apenas por scripts em scripts/*.mjs (não pelo runtime).
#   [infra]    consumido por docker-compose / Portainer — NÃO lido por código.
# ============================================================================


# ----------------------------------------------------------------------------
# APP
# ----------------------------------------------------------------------------
# [optional] URL pública do app. Usado pelo client browser (ex: callback de
# magic link legado). Em prod, setar para o domínio final (ex: https://podzap.wsmart.com.br).
# Fallback em lib/tenant.ts: http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [infra] Mesmo valor, exposto ao container no docker-compose. Não é lido por
# código — docker-compose.yml pode derivar de NEXT_PUBLIC_APP_URL. Manter para
# compat com o stack file.
APP_URL=http://localhost:3000

# [optional] "development" | "production" — Next define automaticamente.
NODE_ENV=development


# ----------------------------------------------------------------------------
# SUPABASE
# ----------------------------------------------------------------------------
# Projeto em https://supabase.com/dashboard → New project
# Valores em: Project Settings → API

# [required] URL do projeto (ex: https://xxxxx.supabase.co). Acessada via `!`
# em lib/supabase/{server,browser,middleware,admin}.ts + proxy.ts.
NEXT_PUBLIC_SUPABASE_URL=

# [required] anon key — pública, safe no client browser (RLS protege).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [required] service role key — SECRETA, bypassa RLS. Nunca exponha ao browser.
# Usada em lib/supabase/admin.ts e scripts de ops.
SUPABASE_SERVICE_ROLE_KEY=

# [infra] Connection string do Postgres (Project Settings → Database). Usada
# por migrations via `supabase db push`. Não é lida por código Next.js.
DATABASE_URL=

# [script] Personal Access Token da dashboard Supabase. Usado por
# scripts/{db-query,gen-types,configure-auth,set-superadmin}.mjs via
# Management API. Não é lido pelo runtime do app.
SUPABASE_ACCESS_TOKEN=

# [script] Project ref do Supabase (ex: vqrqygyfsrjpzkaxjleo). Idem acima.
SUPABASE_PROJECT_REF=


# ----------------------------------------------------------------------------
# UAZAPI — WhatsApp
# ----------------------------------------------------------------------------
# [optional] URL da instância UAZAPI. Fallback em código: https://wsmart.uazapi.com
UAZAPI_BASE_URL=https://wsmart.uazapi.com

# [required-in-practice] Token admin da sua conta UAZAPI (para criar instâncias
# e listar pool). Fallback em código é string vazia — chamadas /instance/init
# falham sem ele. Encontre em: painel UAZAPI → admin.
UAZAPI_ADMIN_TOKEN=

# [required] Secret para validar webhooks vindos da UAZAPI. Sem ele, o endpoint
# /api/webhooks/uazapi retorna 500 (validator.ts aborta).
# Gere com: openssl rand -hex 32
UAZAPI_WEBHOOK_SECRET=


# ----------------------------------------------------------------------------
# AI — GROQ (transcrição de áudio)
# ----------------------------------------------------------------------------
# [required] API key. lib/ai/groq.ts usa requireEnv() → throw se ausente.
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# [optional] Modelo de transcrição. Fallback: whisper-large-v3.
GROQ_STT_MODEL=whisper-large-v3


# ----------------------------------------------------------------------------
# AI — GEMINI (Vision + LLM + TTS)
# ----------------------------------------------------------------------------
# [required] Mesma chave serve para Vision, LLM e Speech.
# lib/ai/gemini-{vision,llm,tts}.ts usam requireEnv() → throw se ausente.
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# [optional] Modelos. Fallbacks nos arquivos lib/ai/gemini-*.ts.
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_LLM_MODEL=gemini-2.5-pro
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts


# ----------------------------------------------------------------------------
# AI — OPENAI (fallback LLM — LEGACY)
# ----------------------------------------------------------------------------
# LEGACY — planejado como fallback no PRD, mas NÃO é lido por nenhum código
# hoje (grep confirma zero referências). Manter como placeholder até decidir
# se implementa o fallback na pós-MVP. Remover se confirmar que não usa.
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4.1-mini


# ----------------------------------------------------------------------------
# INNGEST — workers/filas
# ----------------------------------------------------------------------------
# Em dev, deixe ambas em branco e rode `npx inngest-cli@latest dev`.
# Em prod, obtenha em https://app.inngest.com/.
# As duas são lidas AUTOMATICAMENTE pelo SDK Inngest — não via process.env
# em código podZAP. Não setar em código; só no ambiente.

# [optional-in-dev, required-in-prod] Assinatura dos eventos emitidos.
INNGEST_EVENT_KEY=

# [optional-in-dev, required-in-prod] Verifica requests recebidos de Inngest
# Cloud no handler /api/inngest.
INNGEST_SIGNING_KEY=

# [dev-only] Força o SDK a rotear para o dev server local (127.0.0.1:8288).
# NUNCA setar em prod — se setado, crons não disparam via Inngest Cloud.
# Descomente em dev:
# INNGEST_DEV=1


# ----------------------------------------------------------------------------
# SEGURANÇA
# ----------------------------------------------------------------------------
# [required] Chave AES-256 (base64, 32 bytes) para encriptar tokens de
# instância UAZAPI no banco. lib/crypto.ts faz throw sem ela.
# Gere com: openssl rand -base64 32
ENCRYPTION_KEY=

# [infra] Secret para rotas de cron autenticadas. NÃO é lido por código hoje
# (grep confirma zero referências em process.env). Reservado para quando
# expusermos endpoints HTTP de cron. Passado ao container via stack file.
# Gere com: openssl rand -hex 32
CRON_SECRET=
